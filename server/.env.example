# Copy to .env and edit, then `docker compose --env-file .env up -d`.

# Where the browser should pull the live MJPEG stream from. The ESP32-CAM
# serves this directly (not proxied by the server) so browsers on the same LAN
# can connect with low latency. mDNS works on most home networks.
ESP32_STREAM_URL=http://birb.local/stream

# How much pixel movement counts as "interesting" (0 = anything, 255 = max).
# 2.0 is calibrated against synthetic frames; tune once real footage exists.
# Lower it if real birds aren't being caught; raise it if wind/lighting noise
# is creating false positives.
BIRB_HIGHLIGHT_THRESHOLD=2.0

# Server-side rotation of incoming JPEGs (clockwise degrees). Useful when the
# cam is physically mounted at 90/180/270° relative to the scene's natural
# orientation. Only 0/90/180/270 are honoured; other values are ignored.
# 0 = no rotation (default). Try each multiple of 90 until the gallery looks
# right-side up.
BIRB_ROTATE=0

# Retention. Real-world footprint is ~26 KB/SVGA JPEG → ~2.16 GB/day at 1 fps,
# so non-highlight retention is the main driver. Highlights are tiny and worth
# keeping for a year. Setting BIRB_RETAIN_DAYS to 0 or a negative number
# DISABLES pruning entirely (safety against accidental wipe). The prune task
# runs every BIRB_PRUNE_INTERVAL_S seconds.
#
# Reference sizing at 1 fps:
#   7 days   ~ 15 GB     30 days  ~ 65 GB     90 days  ~195 GB     365 days ~790 GB
BIRB_RETAIN_DAYS=30
BIRB_RETAIN_HIGHLIGHT_DAYS=365
BIRB_PRUNE_INTERVAL_S=3600
