# Copy to .env and edit, then `docker compose --env-file .env up -d`.

# Where the browser should pull the live MJPEG stream from. The ESP32-CAM
# serves this directly (not proxied by the server) so browsers on the same LAN
# can connect with low latency. mDNS works on most home networks.
ESP32_STREAM_URL=http://birb.local/stream

# How much pixel movement counts as "interesting" (0 = anything, 255 = max).
# 2.0 is calibrated against synthetic frames; tune once real footage exists.
# Lower it if real birds aren't being caught; raise it if wind/lighting noise
# is creating false positives.
BIRB_HIGHLIGHT_THRESHOLD=2.0
